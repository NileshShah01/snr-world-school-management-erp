        { "source": "/*/Teacher-Dashboard**", "destination": "/portal/teacher-dashboard.html" },
        { "source": "/*/Admin-Login**", "destination": "/portal/admin-login.html" },
        { "source": "/*/Student-Login**", "destination": "/portal/student-login.html" },
        { "source": "/*/Question-paper-Formator**", "destination": "/portal/tool-question-formatter.html" },
        { "source": "/*/portal/admin-dashboard.html", "destination": "/portal/admin-dashboard.html" },
        { "source": "/*/portal/student-dashboard.html", "destination": "/portal/student-dashboard.html" },
        { "source": "/*/portal/teacher-dashboard.html", "destination": "/portal/teacher-dashboard.html" },
        { "source": "/*/portal/admin-login.html", "destination": "/portal/admin-login.html" },
        { "source": "/*/portal/student-login.html", "destination": "/portal/student-login.html" },
        { "source": "/*/about.html", "destination": "/about.html" },
        { "source": "/*/academics.html", "destination": "/academics.html" },
        { "source": "/*/admissions.html", "destination": "/admissions.html" },
        { "source": "/*/contact.html", "destination": "/contact.html" },
        { "source": "/*/facilities.html", "destination": "/facilities.html" },
        { "source": "/*/gallery.html", "destination": "/gallery.html" },
        { "source": "/*/inquiry.html", "destination": "/inquiry.html" },
        { "source": "/*/css/**", "destination": "/css/:splat" },
        { "source": "/*/js/**", "destination": "/js/:splat" },
        { "source": "/*/images/**", "destination": "/images/:splat" },
        { "source": "/*/", "destination": "/school.html" },
        { "source": "/*", "destination": "/school.html" },
        { "source": "/*/**", "destination": "/school.html" }
      ],
      "headers": [
        { "source": "**/*.html", "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**/*.{js,css}", "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**/*.{png,jpg,jpeg,gif,svg,ico,webp}", "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**/*.{woff,woff2,ttf,otf,eot}", "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**", "headers": [
          { "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'strict-dynamic' https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://cdn.sheetjs.com https://cdn.tailwindcss.com https://checkout.razorpay.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://api.msg91.com https://*.cloudfunctions.net; frame-src 'self' https://*.firebaseapp.com https://apex-public-school-portal.firebaseapp.com https://checkout.razorpay.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" },
          { "key": "Cache-Control", "value": "public, max-age=86400" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]}
      ],
      "trailingSlash": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "_backups/**",
        "Competitors/**",
        "Educationdesk/**",
        "docs/**",
        "Question Paper Template/**",
        "temp_super_admin/**",
        "temp_question_tool/**",
        "scripts/**",
        "*.md",
        "*.zip",
        "package.json",
        "package-lock.json",
        "firestore.rules",
        "firestore.indexes.json",
        "eslint.config.js",
        ".prettierrc",
        ".prettierignore",
        ".stylelintrc.json",
        ".stylelintignore"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  }
}
