{
  "hosting": [
    {
      "target": "school",
      "public": ".",
      "rewrites": [
        { "source": "/", "destination": "/school.html" },
        { "source": "/index.html", "destination": "/school.html" },
        { "source": "/Super-Admin-pro**", "destination": "/portal/super-admin-pro.html" },
        { "source": "/Super-Admin**", "destination": "/portal/super-admin.html" },
        { "source": "/*/Admin-Dashboard**", "destination": "/portal/admin-dashboard.html" },
        { "source": "/*/Student-Dashboard**", "destination": "/portal/student-dashboard.html" },
        { "source": "/*/Admin-Login**", "destination": "/portal/admin-login.html" },
        { "source": "/*/Student-Login**", "destination": "/portal/student-login.html" },
        { "source": "/*/Question-paper-Formator**", "destination": "/portal/tool-question-formatter.html" },
        { "source": "/*/portal/admin-dashboard.html", "destination": "/portal/admin-dashboard.html" },
        { "source": "/*/portal/student-dashboard.html", "destination": "/portal/student-dashboard.html" },
        { "source": "/*/portal/admin-login.html", "destination": "/portal/admin-login.html" },
        { "source": "/*/portal/student-login.html", "destination": "/portal/student-login.html" },
        { "source": "/*/css/**", "destination": "/css/:splat" },
        { "source": "/*/js/**", "destination": "/js/:splat" },
        { "source": "/*/images/**", "destination": "/images/:splat" }
      ],
      "headers": [
        { "source": "**/*.html", "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**", "headers": [
          { "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://cdn.sheetjs.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com; frame-src 'self' https://*.firebaseapp.com https://apex-public-school-portal.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]}
      ],
      "trailingSlash": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "scripts/**",
        "implementation_plan*.md",
        "task.md",
        "walkthrough*.md"
      ]
    },
    {
      "target": "platform",
      "public": ".",
      "rewrites": [
        { "source": "/", "destination": "/platform.html" },
        { "source": "/index.html", "destination": "/platform.html" },
        { "source": "/Super-Admin-pro**", "destination": "/portal/super-admin-pro.html" },
        { "source": "/Super-Admin**", "destination": "/portal/super-admin.html" },
        { "source": "/*/Admin-Dashboard**", "destination": "/portal/admin-dashboard.html" },
        { "source": "/*/Student-Dashboard**", "destination": "/portal/student-dashboard.html" },
        { "source": "/*/Admin-Login**", "destination": "/portal/admin-login.html" },
        { "source": "/*/Student-Login**", "destination": "/portal/student-login.html" },
        { "source": "/*/Question-paper-Formator**", "destination": "/portal/tool-question-formatter.html" },
        { "source": "/*/portal/admin-dashboard.html", "destination": "/portal/admin-dashboard.html" },
        { "source": "/*/portal/student-dashboard.html", "destination": "/portal/student-dashboard.html" },
        { "source": "/*/portal/admin-login.html", "destination": "/portal/admin-login.html" },
        { "source": "/*/portal/student-login.html", "destination": "/portal/student-login.html" },
        { "source": "/*/about.html", "destination": "/about.html" },
        { "source": "/*/academics.html", "destination": "/academics.html" },
        { "source": "/*/admissions.html", "destination": "/admissions.html" },
        { "source": "/*/contact.html", "destination": "/contact.html" },
        { "source": "/*/facilities.html", "destination": "/facilities.html" },
        { "source": "/*/gallery.html", "destination": "/gallery.html" },
        { "source": "/*/inquiry.html", "destination": "/inquiry.html" },
        { "source": "/*/css/**", "destination": "/css/:splat" },
        { "source": "/*/js/**", "destination": "/js/:splat" },
        { "source": "/*/images/**", "destination": "/images/:splat" },
        { "source": "/*/", "destination": "/school.html" },
        { "source": "/*", "destination": "/school.html" },
        { "source": "/*/**", "destination": "/school.html" }
      ],
      "headers": [
        { "source": "**/*.html", "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]},
        { "source": "**", "headers": [
          { "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://cdn.sheetjs.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.io https://firestore.googleapis.com https://identitytoolkit.googleapis.com; frame-src 'self' https://*.firebaseapp.com https://apex-public-school-portal.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
        ]}
      ],
      "trailingSlash": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "scripts/**",
        "implementation_plan*.md",
        "task.md",
        "walkthrough*.md"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
